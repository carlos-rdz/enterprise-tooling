# Copy to `.env` and fill in. `.env` is gitignored.
# All MCP servers fall back to synthetic responses when their env vars are unset,
# so this file is OPTIONAL — the repo works end-to-end with no credentials at all.

# --- Anthropic (required for the raw-form Python agents) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Slack ---
# Create a Slack app at https://api.slack.com/apps, install to your workspace,
# and copy the Bot User OAuth Token (starts with `xoxb-`).
# Suggested bot scopes for full functionality:
#   channels:history, channels:read, groups:history, groups:read,
#   im:write, chat:write, search:read, users:read, users:read.email
SLACK_BOT_TOKEN=xoxb-...

# --- Jira Cloud ---
# JIRA_HOST is your Atlassian Cloud subdomain, e.g. "yourco.atlassian.net"
# JIRA_API_TOKEN is created at https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_HOST=yourco.atlassian.net
JIRA_EMAIL=you@yourco.com
JIRA_API_TOKEN=...

# --- Safety switch ---
# When DRY_RUN=true, all write operations (Slack post/DM, Jira create/comment)
# log to stderr instead of hitting the real API. Reads still go live.
# Leave unset for full read+write.
DRY_RUN=true
